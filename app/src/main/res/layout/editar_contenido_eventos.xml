<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- SCROLL DEL FORMULARIO -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Nombre -->
            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del evento"
                android:padding="12dp"
                android:background="#FFFFFF"/>

            <!-- Tipo -->
            <EditText
                android:id="@+id/etTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tipo de evento"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <!-- Dirección -->
            <EditText
                android:id="@+id/etDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <EditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha (YYYY-MM-DD)"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:focusable="false"
                android:clickable="true" />

            <!-- Público objetivo -->
            <EditText
                android:id="@+id/etPublico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Público objetivo (capellan, personal, familiar, todos)"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <!-- Descripción -->
            <EditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descripción"
                android:minLines="4"
                android:gravity="top"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <!-- Imagen -->
            <EditText
                android:id="@+id/etImagen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Imagen (URL o base64)"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <!-- Propio -->
            <CheckBox
                android:id="@+id/cbPropio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Evento propio"
                android:layout_marginTop="12dp" />


            <!-- Cupo -->
            <EditText
                android:id="@+id/etCupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cupo (opcional)"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"/>

            <!-- Botón Actualizar -->
            <Button
                android:id="@+id/btnActualizar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actualizar"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/azul_oscuro"
                android:textColor="@color/white"/>
        </LinearLayout>

    </ScrollView>

    <!-- PROGRESSBAR CENTRADO SOBRE TODO -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleLarge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
